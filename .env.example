# ARGUS — Autonomous AI Red Team Platform
# Copy this file to .env and fill in the keys you have. At minimum, set ANTHROPIC_API_KEY.

# Anthropic Claude (required for agents, L4 deviation detection, L5 Opus chain synthesis)
ANTHROPIC_API_KEY=sk-ant-...

# Optional multi-provider fallback (ArgusClient will route models if configured)
OPENAI_API_KEY=
GEMINI_API_KEY=

# argus-targets docker-compose passes this through to every target container
# (same key as above — targets need it to power their own agent LLM calls)
